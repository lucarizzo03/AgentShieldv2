APP_ENV=dev
POSTGRES_DSN=postgresql+psycopg://agentshield:agentshield@localhost:5432/agentshield
REDIS_DSN=redis://localhost:6379/0
SLM_BASE_URL=http://localhost:11434
SLM_MODEL_NAME=llama3:8b
HITL_SMS_SENDER=AgentShield
HITL_DEFAULT_TIMEOUT_SECONDS=600
LOOP_WINDOW_SECONDS=60
LOOP_THRESHOLD=5
API_AUTH_HEADER=x-agent-key
SIGNATURE_TOLERANCE_SECONDS=300
JWT_ALGORITHM=HS256
JWT_SECRET=replace-with-strong-jwt-secret
JWT_AUDIENCE=agentshield-api
AGENT_HMAC_SECRET=replace-with-strong-agent-hmac-secret
WEBHOOK_HMAC_SECRET=replace-with-strong-webhook-hmac-secret
SMS_PROVIDER=stub

